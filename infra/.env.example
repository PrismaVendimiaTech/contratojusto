# Shared live runtime values for local execution and `turismo`.
# Programadores should receive only the `demo-window` subset through `mkey`.
# Operator-only values stay in the `ops` environment and should not be shared manually.

# Dokploy / turismo (ops only)
DOKPLOY_URL=http://dokploy.gestionturismo.xyz:3000
DOKPLOY_API_KEY=
DOKPLOY_APP_ID=
DOKPLOY_PROJECT_ID=
DOKPLOY_ENVIRONMENT_ID=

# Frontend live runtime
NEXT_PUBLIC_RUNTIME_MODE=live
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_STELLAR_SIMULATION_ADDRESS=
NEXT_PUBLIC_CONTRACT_ID=
NEXT_PUBLIC_TOKEN_ID=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_WALLETCONNECT_APP_NAME=ContratoJusto
NEXT_PUBLIC_WALLETCONNECT_APP_DESCRIPTION=Contratos laborales digitales para trabajadores informales en Argentina
NEXT_PUBLIC_WALLETCONNECT_APP_URL=https://contratojusto.nuestrascuentitas.com
NEXT_PUBLIC_WALLETCONNECT_APP_ICON=https://contratojusto.nuestrascuentitas.com/icon.png

# AI proxy
AI_PROXY_URL=https://proxy.gestionturismo.xyz/v1/chat/completions
AI_PROXY_KEY=
AI_MODEL=kimi
